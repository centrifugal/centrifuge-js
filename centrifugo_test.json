{
  "client": {
    "insecure": true,
    "concurrency": 8,
    "token": {
      "hmac_secret_key": "secret"
    }
  },
  "log": {
    "level": "trace"
  },
  "http_stream": {
    "enabled": true
  },
  "sse": {
    "enabled": true
  },
  "map_broker": {},
  "shared_poll": {
    "hmac_secret_key": "test-poll-secret"
  },
  "proxies": [
    {
      "name": "poll_backend",
      "endpoint": "http://127.0.0.1:3010/refresh",
      "timeout": "5s"
    }
  ],
  "http_api": {
    "key": "test-api-key"
  },
  "channel": {
    "without_namespace": {
      "presence": true,
      "allowed_delta_types": ["fossil"],
      "delta_publish": true,
      "history_size": 100,
      "history_ttl": "300s",
      "force_recovery": true
    },
    "namespaces": [
      {
        "name": "streamless",
        "subscription_type": "map",
        "map": {
          "mode": "ephemeral",
          "key_ttl": "60s",
          "allow_publish_for_client": true,
          "allow_remove_for_client": true
        },
        "allow_subscribe_for_client": true
      },
      {
        "name": "positioned",
        "subscription_type": "map",
        "map": {
          "mode": "persistent",
          "allow_publish_for_client": true,
          "allow_remove_for_client": true
        },
        "allow_subscribe_for_client": true
      },
      {
        "name": "smallstream",
        "subscription_type": "map",
        "map": {
          "mode": "persistent",
          "stream_size": 2,
          "stream_ttl": "60s",
          "allow_publish_for_client": true,
          "allow_remove_for_client": true
        },
        "allow_subscribe_for_client": true
      },
      {
        "name": "delta",
        "allowed_delta_types": ["fossil"],
        "delta_publish": true,
        "force_recovery": true,
        "history_size": 100,
        "history_ttl": "300s",
        "allow_subscribe_for_client": true,
        "allow_publish_for_subscriber": true
      },
      {
        "name": "mapdelta",
        "subscription_type": "map",
        "map": {
          "mode": "persistent",
          "allow_publish_for_client": true,
          "allow_remove_for_client": true
        },
        "allowed_delta_types": ["fossil"],
        "delta_publish": true,
        "allow_subscribe_for_client": true
      },
      {
        "name": "recovery",
        "force_recovery": true,
        "history_size": 100,
        "history_ttl": "300s",
        "allow_subscribe_for_client": true,
        "allow_publish_for_subscriber": true
      },
      {
        "name": "smallhistory",
        "force_recovery": true,
        "history_size": 2,
        "history_ttl": "300s",
        "allow_subscribe_for_client": true,
        "allow_publish_for_subscriber": true
      },
      {
        "name": "shortttl",
        "subscription_type": "map",
        "map": {
          "mode": "ephemeral",
          "key_ttl": "3s",
          "allow_publish_for_client": true,
          "allow_remove_for_client": true
        },
        "allow_subscribe_for_client": true
      },
      {
        "name": "clientkey",
        "subscription_type": "map",
        "map": {
          "mode": "ephemeral",
          "key_ttl": "60s",
          "client_key": "client_id",
          "allow_publish_for_subscriber": true
        },
        "allow_subscribe_for_client": true
      },
      {
        "name": "prestest",
        "subscription_type": "map",
        "map_clients_presence_channel_prefix": "prescli:",
        "map": {
          "mode": "ephemeral",
          "key_ttl": "60s",
          "allow_publish_for_client": true
        },
        "allow_subscribe_for_client": true
      },
      {
        "name": "prescli",
        "subscription_type": "map_clients",
        "map": {
          "mode": "ephemeral",
          "key_ttl": "60s"
        },
        "allow_subscribe_for_client": true
      },
      {
        "name": "debounced",
        "subscription_type": "map",
        "map": {
          "mode": "ephemeral",
          "key_ttl": "60s",
          "allow_publish_for_client": true,
          "allow_remove_for_client": true
        },
        "allow_subscribe_for_client": true,
        "client_publish_debounce_interval": "50ms"
      },
      {
        "name": "tagged",
        "subscription_type": "map",
        "map": {
          "mode": "persistent",
          "allow_publish_for_client": true,
          "allow_remove_for_client": true
        },
        "allow_subscribe_for_client": true,
        "allow_tags_filter": true
      },
      {
        "name": "poll",
        "subscription_type": "shared_poll",
        "shared_poll": {
          "proxy_name": "poll_backend",
          "mode": "versioned",
          "refresh_interval": "200ms",
          "refresh_batch_size": 100,
          "max_keys_per_connection": 100
        },
        "allow_subscribe_for_client": true
      },
      {
        "name": "pollvl",
        "subscription_type": "shared_poll",
        "shared_poll": {
          "proxy_name": "poll_backend",
          "refresh_interval": "200ms",
          "refresh_batch_size": 100,
          "max_keys_per_connection": 100
        },
        "allow_subscribe_for_client": true
      }
    ]
  }
}
